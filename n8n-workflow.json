        "jsCode": "// スプレッドシートのヘッダー名（1行目と同じ順番で並べる）\nconst headers = [\n  \"会社名\",\n  \"社員数\",\n  \"所在地\",\n  \"電話番号\",\n  \"事業内容\",\n  \"注目箇所\"\n];\n\n// JSONに変換\nconst ai = JSON.parse($input.first().json.output[0].content[0].text);\n\n// 1行分の配列を作る\nconst row = headers.map(h => {\n  const val = ai[h];\n\n  if (Array.isArray(val)) {\n    // 配列 → 箇条書き形式にする\n    return \"・\" + val.join(\"\\n・\");\n  }\n\n  return val ?? \"\";\n});\n\nreturn [\n  {\n    json: {\n      values: row   // Google Sheets に渡す値\n    }\n  }\n];\n\n"
      },
